    "Wait for %@ to finish its current action before deleting its container.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Warten Sie, bis %1$@ seine aktuelle Aktion abgeschlossen hat, bevor Sie seinen Container löschen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Espere a que %1$@ finalice su acción actual antes de eliminar su contenedor."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Attendez que %1$@ termine son action en cours avant de supprimer son conteneur."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ が現在のアクションを完了するまで待ってから、コンテナを削除します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "컨테이너를 삭제하기 전에 %1$@가 현재 작업을 완료할 때까지 기다립니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Espere %1$@ concluir a ação atual antes de apagar o contêiner."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Подождите, пока %1$@ завершит текущее действие, прежде чем удалять свой контейнер."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "等待 %1$@ 完成当前操作，然后再删除其容器。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "等待 %1$@ 完成目前操作，然後再刪除其容器。"
          }
        }
      }
    },
    "Wait for %@ to finish its current session action before starting another executable.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Warten Sie, bis %1$@ seine aktuelle Sitzungsaktion abgeschlossen hat, bevor Sie eine andere ausführbare Datei starten."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Espere a que %1$@ finalice la acción de la sesión actual antes de iniciar otro ejecutable."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Attendez que %1$@ termine son action de session en cours avant de démarrer un autre exécutable."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ が現在のセッション アクションを終了するまで待ってから、別の実行可能ファイルを開始します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "다른 실행 파일을 시작하기 전에 %1$@가 현재 세션 작업을 완료할 때까지 기다리십시오."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Espere %1$@ terminar a ação de sessão atual antes de iniciar outro executável."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Подождите, пока %1$@ завершит текущее действие сеанса, прежде чем запускать другой исполняемый файл."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "等待 %1$@ 完成其当前会话操作，然后再启动另一个可执行文件。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "等待 %1$@ 完成其目前會話操作，然後再啟動另一個執行檔。"
          }
        }
      }
    },
    "Wait for all container activity to stop before changing the active runtime.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "활성 런타임을 변경하기 전에 모든 컨테이너 작업이 끝날 때까지 기다리세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "更改活动运行时前，请等待所有容器任务结束。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "變更使用中的執行環境前，請等待所有容器工作結束。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アクティブなランタイムを変更する前に、すべてのコンテナ処理が終了するまでお待ちください。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Перед сменой активной среды выполнения дождитесь завершения всех операций с контейнерами."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Warten Sie, bis alle Containeraktivitäten beendet sind, bevor Sie die aktive Laufzeitumgebung ändern."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Attendez la fin de toute activité des conteneurs avant de changer l’environnement actif."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Espera a que termine toda la actividad de los contenedores antes de cambiar el entorno activo."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Aguarde o término de todas as atividades dos contêineres antes de alterar o runtime ativo."
          }
        }
      }
    },
    "Wait for all container activity to stop before changing GPTK.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "GPTK를 변경하기 전에 모든 컨테이너 작업이 끝날 때까지 기다리세요."
          }
        },
        "zh-Hans": {
