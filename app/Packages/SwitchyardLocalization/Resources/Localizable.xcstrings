    "1. Open Apple's download page": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "1. Öffnen Sie die Download-Seite von Apple"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "1. Abra la página de descarga de Apple."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "1. Ouvrez la page de téléchargement d'Apple"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "1. Appleのダウンロードページを開きます"
          }
        },
        "ko": {
