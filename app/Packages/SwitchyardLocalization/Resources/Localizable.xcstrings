    "Callback URLs and sign-in tokens are passed through a protected one-time file and are not saved or logged.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Callback-URLs und Anmeldetokens werden nur über eine geschützte Einmaldatei weitergegeben und weder gespeichert noch protokolliert."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las URL de devolución y los tokens de inicio de sesión solo se transfieren mediante un archivo protegido de un solo uso; no se guardan ni se incluyen en los registros."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les URL de rappel et les jetons de connexion transitent uniquement par un fichier à usage unique protégé ; ils ne sont ni enregistrés ni consignés."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "コールバックURLとサインイントークンは、保護された一時ファイルでのみ受け渡され、保存もログ記録もされません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "콜백 URL과 로그인 토큰은 보호된 일회용 파일로만 전달하며, 저장하거나 로그에 남기지 않습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "As URLs de callback e os tokens de início de sessão passam apenas por um arquivo protegido de uso único; eles não são salvos nem registrados."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "URL обратного вызова и токены входа передаются только через защищённый одноразовый файл; они не сохраняются и не попадают в журнал."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "回调 URL 和登录令牌只会通过受保护的一次性文件传递，不会保存或写入日志。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "回呼 URL 和登入權杖只會透過受保護的一次性檔案傳送，不會儲存或寫入記錄。"
          }
        }
      }
    },
