    "%@ is missing from the Open Font Pack cache: %@": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ fehlt im Open-Font-Paket-Cache: %2$@"
          }
        },
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@ is missing from the Open Font Pack cache: %2$@"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Falta %1$@ en la caché paquete de fuentes abiertas: %2$@"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ est absent du cache pack de polices libres : %2$@"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ が オープンフォントパック キャッシュにありません: %2$@"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@가 오픈 폰트 팩 캐시에서 누락되었습니다: %2$@"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ não está no cache do pacote de fontes abertas: %2$@"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ отсутствует в кеше пакет открытых шрифтов: %2$@"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "开放字体包 缓存中缺少 %1$@：%2$@"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "開放字型套件 快取中缺少 %1$@：%2$@"
          }
        }
      }
    },
    "%@ is now the active app-wide runtime.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@가 앱 전체의 활성 런타임으로 설정되었습니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ 现已设为全局活动运行时。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ 現已設為全 App 共用的執行環境。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ をアプリ全体のアクティブなランタイムに設定しました。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ теперь используется как активная среда выполнения во всём приложении."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ ist jetzt die appweit aktive Laufzeitumgebung."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ est désormais l’environnement d’exécution actif de toute l’app."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ es ahora el entorno de ejecución activo de toda la app."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ agora é o runtime ativo de todo o app."
          }
        }
      }
    },
    "%@ was removed from Switchyard, but its folder was already missing.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ wurde aus Switchyard entfernt, aber sein Ordner fehlte bereits."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ se eliminó de Switchyard, pero ya faltaba su carpeta."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ a été supprimé de Switchyard, mais son dossier était déjà manquant."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ は Switchyard から削除されましたが、そのフォルダーはすでに見つかりませんでした。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@가 Switchyard에서 제거되었지만 해당 폴더가 이미 없습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ foi removido do Switchyard, mas a pasta já não existia."
          }
        },
        "ru": {
          "stringUnit": {
