    "Debug run logging enabled (profile=%@, WINEDEBUG=%@, file: %@). The live view is batched and retains its latest %lld entries; this file retains the complete run output.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Debug-Laufprotokollierung aktiviert (Profil=%1$@, WINEDEBUG=%2$@, Datei: %3$@). Die Live-Ansicht wird gestapelt und behält die neuesten %4$lld-Einträge bei. Diese Datei enthält die gesamte Laufausgabe."
          }
        },
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Debug run logging enabled (profile=%1$@, WINEDEBUG=%2$@, file: %3$@). The live view is batched and retains its latest %4$lld entries; this file retains the complete run output."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Registro de ejecución de depuración habilitado (perfil=%1$@, WINEDEBUG=%2$@, archivo: %3$@). La vista en vivo se realiza por lotes y conserva sus últimas entradas %4$lld; este archivo conserva el resultado completo de la ejecución."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Journalisation de l'exécution du débogage activée (profil = %1$@, WINEDEBUG = %2$@, fichier : %3$@). La vue en direct est groupée et conserve ses dernières entrées %4$lld ; ce fichier conserve la sortie complète de l'exécution."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "デバッグ実行ログが有効になっています (プロファイル=%1$@、WINEDEBUG=%2$@、ファイル: %3$@)。ライブ ビューはバッチ処理され、最新の %4$lld エントリが保持されます。このファイルには完全な実行出力が保持されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "디버그 실행 로그를 켰습니다(프로필=%1$@, WINEDEBUG=%2$@, 파일: %3$@). 화면에는 최신 %4$lld개만 나누어 표시하며, 이 파일에는 전체 실행 로그를 보관합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Registro de execução de depuração ativado (profile=%1$@, WINEDEBUG=%2$@, arquivo: %3$@). A visualização ao vivo é agrupada e mantém suas entradas %4$lld mais recentes; esse arquivo mantém a saída completa da execução."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ведение журнала отладки включено (профиль=%1$@, WINEDEBUG=%2$@, файл: %3$@). Просмотр в реальном времени группируется и сохраняет последние записи %4$lld; этот файл сохраняет полный результат выполнения."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "启用调试运行日志记录（配置文件 = %1$@，WINEDEBUG = %2$@，文件：%3$@）。实时查看是批量的，保留其最新的%4$lld条目；该文件保留完整的运行输出。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "啟用偵錯運行日誌記錄（設定檔 = %1$@，WINEDEBUG = %2$@，檔案：%3$@）。即時查看是批次的，保留其最新的%4$lld條目；該檔案保留完整的運行輸出。"
          }
        }
      }
    },
