    "%lld high-volume log entries were omitted from the live view; the protected per-run debug log retains the complete output when developer logging is enabled.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$lld hochvolumigen Logbucheinträge wurden aus der Live-Ansicht ausgelassen; Das geschützte Debuglog pro Ausführung speichert die vollständige Ausgabe, wenn das Entwicklerlogging aktiviert ist."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$lld entradas de registro de alto volumen se omitieron de la vista en directo; El registro de depuración protegido por ejecución conserva la salida completa cuando el registro de desarrollador está habilitado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$lld entrées de journal à grand volume ont été omis de la vue en direct ; Le journal de débogage protégé par exécution conserve la sortie complète lorsque la journalisation développeur est activée."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$lld大量のログエントリはライブビューから除外され、開発者ログが有効化されている場合でも、保護された実行ごとのデバッグログは完全な出力を保持します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "라이브 화면에서 로그 %1$lld개를 생략했습니다. 개발자 로깅이 켜져 있으면 실행별 디버그 로그에서 전체 내용을 확인할 수 있습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$lld entradas de log de alto volume foram omitidas da visualização ao vivo. Quando o log de desenvolvedor está ativo, o arquivo de depuração protegido de cada execução preserva a saída completa."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$lld записи в журнале с большим объёмом были опущены в прямом эфире; Защищённый журнал отладки за запуск сохраняет полный результат при включении логирования разработчика."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$lld高流量日志条目被从实时视图中省略;当启用开发者日志时，受保护的每次运行调试日志会保留完整的输出。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$lld高容量的日誌條目未從即時檢視中顯示;當啟用開發者日誌時，受保護的每次執行除錯日誌會保留完整輸出。"
          }
        }
      }
    },
