            "state": "translated",
            "value": "Normalmente esto sólo lleva un momento."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cela ne prend normalement qu'un instant."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "通常、これにはほんの一瞬しかかかりません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "보통 잠시만 기다리면 됩니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Isso normalmente leva apenas um momento."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Обычно это занимает всего мгновение."
          }
        },
