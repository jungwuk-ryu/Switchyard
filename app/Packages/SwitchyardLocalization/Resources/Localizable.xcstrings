        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les métadonnées de la version sont incomplètes."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "リリースメタデータが不完全です。"
