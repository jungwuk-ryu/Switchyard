    "The Steam installer could not be opened. Check Logs for details, then try again.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das Steam-Installationsprogramm konnte nicht geöffnet werden. Überprüfen Sie die Protokolle auf Details und versuchen Sie es dann erneut."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo abrir el instalador Steam. Consulte Registros para obtener más detalles y vuelva a intentarlo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le programme d'installation de Steam n'a pas pu être ouvert. Consultez les journaux pour plus de détails, puis réessayez."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Steam インストーラーを開けませんでした。詳細についてはログを確認し、再試行してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Steam 설치 프로그램을 열 수 없습니다. 자세한 내용은 로그를 확인한 후 다시 시도하세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
