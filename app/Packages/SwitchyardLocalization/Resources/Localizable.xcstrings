    "Switchyard Wine runtime %@ (%@) found at %@. PE architectures: %@.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard Wine Laufzeit %1$@ (%2$@) gefunden unter %3$@. PE-Architekturen: %4$@."
          }
        },
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Switchyard Wine runtime %1$@ (%2$@) found at %3$@. PE architectures: %4$@."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard Wine tiempo de ejecución %1$@ (%2$@) encontrado en %3$@. Arquitecturas PE: %4$@."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Exécution Switchyard Wine %1$@ (%2$@) trouvée sur %3$@. Architectures PE : %4$@."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard Wine ランタイム %1$@ (%2$@) が %3$@ で見つかりました。 PE アーキテクチャ: %4$@。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard Wine 런타임 %1$@(%2$@)가 %3$@에서 발견되었습니다. PE 아키텍처: %4$@."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Runtime do Wine do Switchyard %1$@ (%2$@) encontrado em %3$@. Arquiteturas PE: %4$@."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard Wine среда выполнения %1$@ (%2$@) находится по адресу %3$@. PE архитектуры: %4$@."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard Wine 运行时 %1$@ (%2$@) 在 %3$@ 中找到。 PE 架构：%4$@。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard Wine 運行時 %1$@ (%2$@) 在 %3$@ 中找到。 PE 架構：%4$@。"
          }
        }
      }
    },
    "Switchyard Wine runtime %@ does not record a source revision. Rebuild it from the pinned switchyard-wine repository.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard Wine Laufzeit %1$@ zeichnet keine Quellrevision auf. Erstellen Sie es aus dem angehefteten switchyard-wine-Repository neu."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard Wine el tiempo de ejecución %1$@ no registra una revisión de origen. Reconstrúyelo desde el repositorio switchyard-wine anclado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'environnement d'exécution Switchyard Wine %1$@ n'enregistre pas de révision source. Reconstruisez-le à partir du référentiel switchyard-wine épinglé."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard Wine ランタイム %1$@ はソース リビジョンを記録しません。固定された switchyard-wine リポジトリから再構築します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard Wine 런타임 %1$@에 소스 리비전 정보가 없습니다. 고정된 switchyard-wine 저장소에서 다시 빌드하세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O runtime do Wine do Switchyard %1$@ não registra uma revisão do código-fonte. Recompile-o a partir da revisão fixada do repositório switchyard-wine."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard Wine Среда выполнения %1$@ не записывает исходную версию. Пересоберите его из закрепленного репозитория switchyard-wine."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard Wine 运行时 %1$@ 不记录源修订。从固定的 switchyard-wine 存储库重建它。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard Wine 運行時 %1$@ 不記錄來源修訂。從固定的 switchyard-wine 儲存庫重建它。"
          }
        }
      }
    },
    "Switchyard Wine runtime %@ is selected at %@, but it is missing PE architecture(s): %@. Rebuild the Switchyard WoW64 runtime before running 32-bit Windows installers or programs.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard Wine Laufzeit %1$@ ist bei %2$@ ausgewählt, aber es fehlen PE Architektur(en): %3$@. Erstellen Sie die Switchyard WoW64-Laufzeit neu, bevor Sie 32-Bit-Windows-Installationsprogramme oder -Programme ausführen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Switchyard Wine runtime %1$@ is selected at %2$@, but it is missing PE architecture(s): %3$@. Rebuild the Switchyard WoW64 runtime before running 32-bit Windows installers or programs."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard Wine tiempo de ejecución %1$@ está seleccionado en %2$@, pero faltan las arquitecturas PE: %3$@. Reconstruya el tiempo de ejecución Switchyard WoW64 antes de ejecutar instaladores o programas Windows de 32 bits."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le runtime Switchyard Wine %1$@ est sélectionné à %2$@, mais il manque la ou les architectures PE : %3$@. Reconstruisez le runtime Switchyard WoW64 avant d'exécuter les programmes d'installation ou les programmes Windows 32 bits."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard Wine ランタイム %1$@ が %2$@ で選択されていますが、PE アーキテクチャ: %3$@ がありません。 32 ビット Windows インストーラーまたはプログラムを実行する前に、Switchyard WoW64 ランタイムを再構築します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard Wine 런타임 %1$@가 %2$@에서 선택되었지만 PE 아키텍처(%3$@)가 누락되었습니다. 32비트 Windows 설치 프로그램 또는 프로그램을 실행하기 전에 Switchyard WoW64 런타임을 다시 빌드하세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O runtime do Wine do Switchyard %1$@ foi selecionado em %2$@, mas não contém as arquiteturas PE: %3$@. Recompile o runtime WoW64 antes de executar instaladores ou programas do Windows de 32 bits."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard Wine. Среда выполнения %1$@ выбрана в %2$@, но в ней отсутствуют архитектуры PE: %3$@. Пересоберите среду выполнения Switchyard WoW64 перед запуском 32-разрядных установщиков или программ Windows."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在 %2$@ 处选择了 Switchyard Wine 运行时 %1$@，但缺少 PE 架构：%3$@。在运行 32 位 Windows 安装程序或程序之前重建 Switchyard WoW64 运行时。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在 %2$@ 處選擇了 Switchyard Wine 運行時 %1$@，但缺少 PE 架構：%3$@。在執行 32 位元 Windows 安裝程式或程式之前重建 Switchyard WoW64 運行時。"
          }
        }
      }
    },
    "Switchyard Wine runtime %@ was built from a dirty source tree at %@. Build a clean pinned revision before release use.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard Wine Laufzeit %1$@ wurde aus einem fehlerhaften Quellbaum bei %2$@ erstellt. Erstellen Sie vor der Release-Verwendung eine sauber angeheftete Revision."
          }
        },
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Switchyard Wine runtime %1$@ was built from a dirty source tree at %2$@. Build a clean pinned revision before release use."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard Wine El tiempo de ejecución %1$@ se creó a partir de un árbol de fuentes sucias en %2$@. Cree una revisión fijada limpia antes de su uso."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le runtime Switchyard Wine %1$@ a été construit à partir d'une arborescence source sale sur %2$@. Créez une révision épinglée propre avant l’utilisation de la version."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard Wine ランタイム %1$@ は、%2$@ のダーティ ソース ツリーから構築されました。リリースで使用する前に、クリーンな固定リビジョンをビルドします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard Wine 런타임 %1$@는 %2$@ 소스 트리의 커밋되지 않은 변경 사항을 포함합니다. 릴리스에 사용하기 전에 고정된 리비전에서 깨끗하게 다시 빌드하세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O runtime do Wine do Switchyard %1$@ foi compilado com alterações não confirmadas em %2$@. Para distribuição, compile uma cópia limpa da revisão fixada."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard Wine. Среда выполнения %1$@ была собрана из грязного дерева исходного кода %2$@. Перед использованием выпуска создайте чистую закрепленную версию."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard Wine 运行时 %1$@ 是从 %2$@ 的脏源树构建的。在发布使用之前构建一个干净的固定修订版。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard Wine 運行時 %1$@ 是從 %2$@ 的髒源樹建構的。在發布使用之前建立一個乾淨的固定修訂版。"
          }
        }
      }
    },
    "Switchyard Wine runtime %@ was built from source %@, but this Switchyard build pins %@. Rebuild the runtime from the pinned revision.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard Wine Laufzeit %1$@ wurde aus der Quelle %2$@ erstellt, aber dieser Switchyard-Build steckt %3$@ fest. Erstellen Sie die Laufzeit aus der angehefteten Revision neu."
          }
        },
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Switchyard Wine runtime %1$@ was built from source %2$@, but this Switchyard build pins %3$@. Rebuild the runtime from the pinned revision."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard Wine tiempo de ejecución %1$@ se compiló a partir de la fuente %2$@, pero este Switchyard construye los pines %3$@. Reconstruya el tiempo de ejecución a partir de la revisión fijada."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le runtime Switchyard Wine %1$@ a été construit à partir de la source %2$@, mais cette version Switchyard épingle %3$@. Reconstruisez le runtime à partir de la révision épinglée."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard Wine ランタイム %1$@ はソース %2$@ からビルドされましたが、この Switchyard ビルドは %3$@ を固定します。固定されたリビジョンからランタイムを再構築します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard Wine 런타임 %1$@는 소스 %2$@에서 빌드되었지만, 이 Switchyard 빌드는 %3$@ 리비전으로 고정되어 있습니다. 고정된 리비전에서 런타임을 다시 빌드하세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O runtime do Wine do Switchyard %1$@ foi compilado da revisão %2$@, mas esta versão do Switchyard exige %3$@. Recompile o runtime a partir da revisão fixada."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard Wine среда выполнения %1$@ была собрана из исходного кода %2$@, но в этой сборке Switchyard используются контакты %3$@. Пересоберите среду выполнения из закрепленной версии."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard Wine 运行时 %1$@ 是从源 %2$@ 构建的，但此 Switchyard 构建引脚 %3$@。从固定版本重建运行时。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard Wine 運行時 %1$@ 是從來源 %2$@ 建構的，但此 Switchyard 建構引腳 %3$@。從固定版本重建運行時。"
          }
        }
      }
    },
    "Switchyard accepts only the official HTTPS download and keeps it in a private cache.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard akzeptiert nur den offiziellen HTTPS-Download und speichert ihn in einem privaten Cache."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard acepta solo la descarga oficial de HTTPS y la guarda en un caché privado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard accepte uniquement le téléchargement officiel HTTPS et le conserve dans un cache privé."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard は、公式の HTTPS ダウンロードのみを受け入れ、プライベート キャッシュに保持します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard는 공식 HTTPS 다운로드만 허용하고 이를 개인 캐시에 보관합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard aceita apenas o download oficial HTTPS e o mantém em um cache privado."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard принимает только официальную загрузку HTTPS и сохраняет ее в частном кеше."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard 仅接受官方 HTTPS 下载并将其保存在私人缓存中。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard 僅接受官方 HTTPS 下載並將其保存在私人快取中。"
          }
        }
      }
    },
    "Switchyard can remove only a runtime stored directly in its managed cache.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard가 직접 관리하는 캐시에 저장된 런타임만 제거할 수 있습니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard 只能移除直接存储在其托管缓存中的运行时。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard 只能移除直接儲存在其管理快取中的執行環境。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard が直接管理するキャッシュに保存されたランタイムだけを削除できます。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard может удалить только среду выполнения, которая хранится непосредственно в управляемом кэше."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard kann nur Laufzeitumgebungen entfernen, die direkt im verwalteten Cache gespeichert sind."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard peut uniquement supprimer un environnement stocké directement dans son cache géré."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard solo puede eliminar un entorno almacenado directamente en su caché gestionada."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O Switchyard só pode remover um runtime armazenado diretamente no cache gerenciado."
          }
        }
      }
    },
    "Switchyard could not close every Windows app. Save your work, close any remaining windows, and try again.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard konnte nicht jede Windows-App schließen. Speichern Sie Ihre Arbeit, schließen Sie alle verbleibenden Fenster und versuchen Sie es erneut."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard no pudo cerrar todas las aplicaciones Windows. Guarde su trabajo, cierre las ventanas restantes y vuelva a intentarlo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard n'a pas pu fermer toutes les applications Windows. Enregistrez votre travail, fermez toutes les fenêtres restantes et réessayez."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard はすべての Windows アプリを閉じることができませんでした。作業内容を保存し、残っているウィンドウを閉じて、もう一度試してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard는 모든 Windows 앱을 닫을 수 없습니다. 작업 내용을 저장하고 나머지 창을 모두 닫은 후 다시 시도하세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O Switchyard não conseguiu fechar todos os aplicativos do Windows. Salve seu trabalho, feche as janelas restantes e tente novamente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard не удалось закрыть все приложения Windows. Сохраните работу, закройте все оставшиеся окна и повторите попытку."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard 无法关闭每个 Windows 应用程序。保存您的工作，关闭所有剩余的窗口，然后重试。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard 無法關閉每個 Windows 應用程式。儲存您的工作，關閉所有剩餘的窗口，然後重試。"
          }
        }
      }
    },
    "Switchyard could not inspect this Wine session.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard konnte diese Wine-Sitzung nicht überprüfen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard no pudo inspeccionar esta sesión Wine."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard n'a pas pu inspecter cette session Wine."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard は、この Wine セッションを検査できませんでした。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard는 이 Wine 세션을 검사할 수 없습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O Switchyard não conseguiu inspecionar esta sessão do Wine."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard не удалось проверить этот сеанс Wine."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard 无法检查此 Wine 会话。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard 無法檢查此 Wine 會話。"
          }
        }
      }
    },
    "Switchyard could not protect the downloaded installer in its private cache: %@": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard konnte das heruntergeladene Installationsprogramm in seinem privaten Cache nicht schützen: %1$@"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard no pudo proteger el instalador descargado en su caché privada: %1$@"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard n'a pas pu protéger le programme d'installation téléchargé dans son cache privé : %1$@"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard は、プライベート キャッシュ内のダウンロードされたインストーラーを保護できませんでした: %1$@"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard는 다운로드한 설치 프로그램을 개인 캐시(%1$@)에서 보호할 수 없습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard não conseguiu proteger o instalador baixado em seu cache privado: %1$@"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard не удалось защитить загруженный установщик в своем личном кеше: %1$@"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard 无法保护其私有缓存中下载的安装程序：%1$@"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard 無法保護其私人快取中下載的安裝程式：%1$@"
          }
        }
      }
    },
    "Switchyard currently requires an Apple Silicon Mac running macOS 14 or later.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard benötigt einen Mac mit Apple Silicon und macOS 14 oder neuer."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard requiere un Mac con Apple Silicon y macOS 14 o posterior."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard nécessite un Mac avec puce Apple et macOS 14 ou version ultérieure."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyardを使用するには、Apple Silicon搭載MacとmacOS 14以降が必要です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard에는 Apple Silicon Mac과 macOS 14 이상이 필요합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O Switchyard requer um Mac com Apple Silicon e macOS 14 ou posterior."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Для работы Switchyard требуется Mac с Apple Silicon и macOS 14 или новее."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard 需要配备 Apple Silicon 且运行 macOS 14 或更高版本的 Mac。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard 需要配備 Apple Silicon 且執行 macOS 14 或以上版本的 Mac。"
          }
        }
      }
    },
    "Switchyard does not download or bundle GPTK. Apple handles sign-in and license acceptance; Switchyard imports only after checking the DMG's executable code for Apple signatures.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard lädt GPTK nicht herunter oder bündelt es nicht. Apple kümmert sich um die Anmeldung und die Lizenzannahme; Switchyard importiert erst, nachdem der ausführbare Code der DMG auf Apple-Signaturen überprüft wurde."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard no descarga ni incluye GPTK. Apple maneja el inicio de sesión y la aceptación de licencias; Switchyard importa solo después de verificar el código ejecutable de DMG para buscar firmas de Apple."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard ne télécharge ni ne regroupe GPTK. Apple gère la connexion et l'acceptation de la licence ; Switchyard importe uniquement après avoir vérifié le code exécutable du DMG pour les signatures Apple."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard は、GPTK をダウンロードまたはバンドルしません。 Apple がサインインとライセンスの受け入れを処理します。 Switchyard は、DMG の実行可能コードで Apple 署名を確認した後にのみインポートします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard는 GPTK를 다운로드하거나 번들링하지 않습니다. Apple은 로그인 및 라이센스 승인을 처리합니다. Switchyard는 DMG의 실행 코드에서 Apple 서명을 확인한 후에만 가져옵니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard não baixa nem inclui GPTK. A Apple cuida do login e aceitação de licenças; Switchyard importa somente após verificar o código executável do DMG para assinaturas Apple."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard не загружает и не связывает GPTK. Apple осуществляет вход в систему и принятие лицензии; Switchyard импортируется только после проверки исполняемого кода DMG на наличие подписей Apple."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard 不下载或捆绑 GPTK。 Apple 处理登录和许可接受； Switchyard 仅在检查 DMG 的可执行代码的 Apple 签名后导入。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard 不下載或捆綁 GPTK。 Apple 處理登入和授權接受；Switchyard 僅在檢查 DMG 的可執行程式碼的 Apple 簽章後匯入。"
          }
        }
      }
    },
    "Switchyard downloads SteamSetup.exe directly from Valve over HTTPS.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard lädt SteamSetup.exe direkt von Valve über HTTPS herunter."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard descarga SteamSetup.exe directamente desde Valve a través de HTTPS."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard télécharge SteamSetup.exe directement à partir de Valve via HTTPS."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard は、HTTPS を介して Valve から SteamSetup.exe を直接ダウンロードします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard는 HTTPS를 통해 Valve에서 직접 SteamSetup.exe를 다운로드합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O Switchyard baixa o SteamSetup.exe diretamente da Valve por HTTPS."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard загружает SteamSetup.exe непосредственно из Valve через HTTPS."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard 通过 HTTPS 直接从 Valve 下载 SteamSetup.exe。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard 透過 HTTPS 直接從 Valve 下載 SteamSetup.exe。"
          }
        }
      }
    },
    "Switchyard downloads only Valve's installer. The normal Steam screens handle games, updates, and account sign-in.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard lädt nur das Installationsprogramm von Valve herunter. Die normalen Steam-Bildschirme verwalten Spiele, Updates und Kontoanmeldungen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard descarga únicamente el instalador de Valve. Las pantallas normales Steam manejan juegos, actualizaciones e inicio de sesión de cuenta."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard télécharge uniquement le programme d'installation de Valve. Les écrans Steam normaux gèrent les jeux, les mises à jour et la connexion au compte."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard は、Valve のインストーラーのみをダウンロードします。通常の Steam 画面は、ゲーム、アップデート、アカウントのサインインを処理します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard는 Valve의 설치 프로그램만 다운로드합니다. 일반적인 Steam 화면은 게임, 업데이트 및 계정 로그인을 처리합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O Switchyard baixa apenas o instalador da Valve. As telas normais do Steam gerenciam jogos, atualizações e o login da conta."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard загружает только установщик Valve. Обычные экраны Steam обрабатывают игры, обновления и вход в учетную запись."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard 仅下载 Valve 的安装程序。普通的 Steam 屏幕处理游戏、更新和帐户登录。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard 僅下載 Valve 的安裝程式。普通的 Steam 螢幕處理遊戲、更新和帳戶登入。"
          }
        }
      }
    },
    "Switchyard installs OFL Noto fonts into containers and maps common Windows font family names without bundling Microsoft fonts.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard installiert OFL Noto-Schriftarten in Containern und ordnet gängige Windows-Schriftfamiliennamen zu, ohne Microsoft-Schriftarten zu bündeln."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard instala las fuentes Noto OFL en contenedores y asigna nombres de familias de fuentes Windows comunes sin agrupar fuentes de Microsoft."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard installe les polices OFL Noto dans des conteneurs et mappe les noms de familles de polices Windows courantes sans regrouper les polices Microsoft."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard は、OFL Noto フォントをコンテナーにインストールし、Microsoft フォントをバンドルせずに一般的な Windows フォント ファミリ名をマップします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard는 OFL Noto 글꼴을 컨테이너에 설치하고 Microsoft 글꼴을 번들링하지 않고 일반적인 Windows 글꼴 제품군 이름을 매핑합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O Switchyard instala fontes Noto com licença OFL nos contêineres e mapeia nomes comuns de famílias de fontes do Windows sem incluir fontes da Microsoft."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard устанавливает шрифты OFL Noto в контейнеры и сопоставляет общие имена семейств шрифтов Windows без объединения шрифтов Microsoft."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard 将 OFL Noto 字体安装到容器中，并映射常见的 Windows 字体系列名称，而无需捆绑 Microsoft 字体。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard 將 OFL Noto 字型安裝到容器中，並對應常見的 Windows 字型系列名稱，而無需捆綁 Microsoft 字型。"
          }
        }
      }
    },
    "Switchyard is downloading and verifying the files it needs. Keep the app open while this finishes.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard lädt die benötigten Dateien herunter und überprüft sie. Lassen Sie die App geöffnet, während der Vorgang abgeschlossen ist."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard está descargando y verificando los archivos que necesita. Mantén la aplicación abierta mientras esto termina."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard télécharge et vérifie les fichiers dont il a besoin. Gardez l'application ouverte pendant que cela se termine."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard は、必要なファイルをダウンロードして確認しています。これが完了するまでアプリを開いたままにしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard가 필요한 파일을 다운로드하고 확인하는 중입니다. 이 작업이 완료되는 동안 앱을 열어두세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard está baixando e verificando os arquivos que precisa. Mantenha o app aberto enquanto isso termina."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard загружает и проверяет необходимые файлы. Держите приложение открытым, пока это закончится."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard 正在下载并验证所需的文件。完成此操作后，保持应用程序打开。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard 正在下載並驗證所需的檔案。完成此操作後，請保持應用程式開啟。"
          }
        }
      }
    },
    "Switchyard is ready": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard ist bereit"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard está listo"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard est prêt"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard の準備ができました"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard가 준비되었습니다"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard está pronto"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard готов."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard 已准备好"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard 已準備好"
          }
        }
      }
    },
    "Switchyard only installs a runtime after its online release matches this app's signed compatibility policy.": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard installiert eine Laufzeitumgebung erst, wenn ihre Online-Veröffentlichung mit der signierten Kompatibilitätsrichtlinie dieser App übereinstimmt."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard solo instala un tiempo de ejecución después de que su lanzamiento en línea coincida con la política de compatibilidad firmada de esta aplicación."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard installe un runtime uniquement une fois que sa version en ligne correspond à la politique de compatibilité signée de cette application."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard は、オンライン リリースがこのアプリの署名済み互換性ポリシーと一致した場合にのみランタイムをインストールします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard는 온라인 릴리스가 이 앱의 서명된 호환 정책과 일치할 때만 런타임을 설치합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O Switchyard só instala um runtime quando a versão online corresponde à política de compatibilidade assinada deste app."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard устанавливает среду выполнения только после того, как ее онлайн-выпуск соответствует подписанной политике совместимости этого приложения."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard 仅在其在线版本与此应用程序的签名兼容性策略匹配后安装运行时。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard 僅在其線上版本與此應用程式的簽章相容性原則相符後安裝執行時間。"
          }
        }
      }
    },
    "Switchyard pins one recommended runtime for automatic setup and verifies every manually selected official release before installation.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard는 자동 설정에 사용할 권장 런타임 하나를 고정하고, 수동으로 선택한 모든 공식 릴리스는 설치 전에 검증합니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard 会为自动设置固定一个推荐运行时，并在安装前验证每个手动选择的官方版本。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard 會為自動設定固定一個建議的執行環境，並在安裝前驗證每個手動選擇的官方版本。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard は自動セットアップ用に推奨ランタイムを 1 つ固定し、手動で選択した公式リリースはインストール前に必ず検証します。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard закрепляет одну рекомендуемую среду выполнения для автоматической настройки и проверяет каждый выбранный вручную официальный выпуск перед установкой."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard legt eine empfohlene Laufzeitumgebung für die automatische Einrichtung fest und überprüft jede manuell ausgewählte offizielle Version vor der Installation."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard fixe un environnement recommandé pour la configuration automatique et vérifie chaque version officielle choisie manuellement avant son installation."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard fija un entorno recomendado para la configuración automática y verifica cada versión oficial elegida manualmente antes de instalarla."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O Switchyard fixa um runtime recomendado para a configuração automática e verifica cada versão oficial escolhida manualmente antes da instalação."
          }
        }
      }
    },
    "Switchyard v1 supports Apple Silicon only.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard v1 unterstützt nur Apple Silicon."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard v1 solo admite Apple Silicon."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard v1 prend en charge uniquement Apple Silicon."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard v1 は Apple Silicon のみをサポートします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard v1은 Apple Silicon만 지원합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard v1 suporta apenas Apple Silicon."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard v1 поддерживает только Apple Silicon."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard v1 仅支持 Apple Silicon。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard v1 僅支援 Apple Silicon。"
          }
        }
      }
    },
    "Switchyard verifies the executable code before copying it into its private cache.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard überprüft den ausführbaren Code, bevor er ihn in seinen privaten Cache kopiert."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard verifica el código ejecutable antes de copiarlo en su caché privada."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard vérifie le code exécutable avant de le copier dans son cache privé."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard は、実行可能コードをプライベート キャッシュにコピーする前に検証します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard는 실행 코드를 개인 캐시에 복사하기 전에 확인합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard verifica o código executável antes de copiá-lo para seu cache privado."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard проверяет исполняемый код перед копированием его в свой частный кэш."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard 在将可执行代码复制到其私有缓存之前对其进行验证。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard 在將可執行程式碼複製到其私人快取之前對其進行驗證。"
          }
        }
      }
    },
    "Switchyard will check this Mac, download its compatibility files, and guide you through the one Apple download it cannot provide itself. Your apps and games stay on this Mac.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard überprüft diesen Mac, lädt seine Kompatibilitätsdateien herunter und führt Sie durch den Download, den Apple nicht selbst bereitstellen kann. Ihre Apps und Spiele bleiben auf diesem Mac."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard verificará esta Mac, descargará sus archivos de compatibilidad y lo guiará a través de la descarga de Apple que no puede proporcionar por sí misma. Tus aplicaciones y juegos permanecen en esta Mac."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard vérifiera ce Mac, téléchargera ses fichiers de compatibilité et vous guidera à travers le téléchargement Apple qu'il ne peut pas fournir lui-même. Vos applications et jeux restent sur ce Mac."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard は、この Mac をチェックし、互換性ファイルをダウンロードし、Apple 自体が提供できないダウンロード方法を案内します。アプリとゲームはこの Mac 上に残ります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard는 이 Mac을 확인하고 호환 파일을 다운로드하며 자체적으로 제공할 수 없는 Apple 다운로드를 안내합니다. 앱과 게임은 이 Mac에 그대로 유지됩니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard vai verificar este Mac, baixar seus arquivos de compatibilidade e te guiar pelo único download da Apple que ele não pode fornecer para si mesmo. Seus aplicativos e jogos ficam neste Mac."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard проверит этот Mac, загрузит файлы совместимости и проведет вас через ту загрузку Apple, которую он не может предоставить сам. Ваши приложения и игры останутся на этом Mac."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard 将检查此 Mac，下载其兼容性文件，并指导您完成 Apple 无法自行提供的下载。您的应用程序和游戏将保留在这台 Mac 上。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard 將檢查此 Mac，下載其相容性文件，並引導您完成 Apple 無法自行提供的下載。您的應用程式和遊戲將保留在這台 Mac 上。"
          }
        }
      }
    },
    "Switchyard will guide you through the remaining steps before installing a Windows app.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard führt Sie durch die verbleibenden Schritte vor der Installation einer Windows-App."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard lo guiará a través de los pasos restantes antes de instalar una aplicación Windows."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard vous guidera à travers les étapes restantes avant d'installer une application Windows."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard では、Windows アプリをインストールする前の残りの手順について説明します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard는 Windows 앱을 설치하기 전에 나머지 단계를 안내합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard vai te guiar pelas etapas restantes antes de instalar um aplicativo Windows."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard проведет вас через оставшиеся шаги перед установкой приложения Windows."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard 将引导您完成安装 Windows 应用程序之前的剩余步骤。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard 將引導您完成安裝 Windows 應用程式之前的剩餘步驟。"
          }
        }
      }
    },
    "Switchyard will not browse a path outside this container.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard durchsucht keinen Pfad außerhalb dieses Containers."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard no buscará una ruta fuera de este contenedor."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard ne parcourra pas un chemin en dehors de ce conteneur."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard は、このコンテナーの外部のパスを参照しません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard는 이 컨테이너 외부의 경로를 탐색하지 않습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O Switchyard não abrirá um caminho fora deste contêiner."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard не будет просматривать путь за пределами этого контейнера."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard 不会浏览此容器之外的路径。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard 不會瀏覽此容器以外的路徑。"
          }
        }
      }
    },
    "Switchyard will open Apple's Rosetta installer. Continuing accepts Apple's Rosetta software license; macOS handles any approval that is required.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard öffnet das Rosetta-Installationsprogramm von Apple. Continuing akzeptiert die Rosetta-Softwarelizenz von Apple; macOS kümmert sich um alle erforderlichen Genehmigungen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard abrirá el instalador Rosetta de Apple. Continuar acepta la licencia de software Rosetta de Apple; macOS maneja cualquier aprobación que se requiera."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard ouvrira le programme d'installation Rosetta d'Apple. Continuer accepte la licence du logiciel Rosetta d'Apple ; macOS gère toute approbation requise."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard は Apple の Rosetta インストーラーを開きます。続行すると、Apple の Rosetta ソフトウェア ライセンスが受け入れられます。 macOS は、必要な承認を処理します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard는 Apple의 Rosetta 설치 프로그램을 엽니다. 계속하면 Apple의 Rosetta 소프트웨어 라이센스에 동의합니다. macOS는 필요한 모든 승인을 처리합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O Switchyard abrirá o instalador do Rosetta da Apple. Ao continuar, você aceita a licença de software do Rosetta; o macOS solicitará as aprovações necessárias."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard откроет установщик Apple Rosetta. Продолжается принятие лицензии на программное обеспечение Apple Rosetta; macOS обрабатывает все необходимые утверждения."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard 将打开 Apple 的 Rosetta 安装程序。继续接受Apple的Rosetta软件许可； macOS 处理所需的任何批准。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard 將開啟 Apple 的 Rosetta 安裝程式。繼續接受Apple的Rosetta軟體授權； macOS 處理所需的任何批准。"
          }
        }
      }
    },
    "Switchyard will redact common secrets and your home folder path before copying.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard schwärzt vor dem Kopieren allgemeine Geheimnisse und den Pfad Ihres Home-Ordners."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard redactará los secretos comunes y la ruta de su carpeta de inicio antes de copiar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard supprimera les secrets communs et le chemin de votre dossier personnel avant la copie."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard は、コピーする前に共通のシークレットとホーム フォルダーのパスを編集します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard는 복사하기 전에 일반 비밀과 홈 폴더 경로를 수정합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Antes de copiar, o Switchyard ocultará dados sensíveis comuns e o caminho da sua pasta pessoal."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard отредактирует общие секреты и путь к вашей домашней папке перед копированием."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard 将在复制之前编辑常见机密和您的主文件夹路径。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard 將在複製之前編輯常見機密和您的主資料夾路徑。"
          }
