    "Open Font Pack could not be prepared; continuing launch without additional font fallback: %@": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Open-Font-Paket konnte nicht vorbereitet werden; Fortsetzung des Starts ohne zusätzlichen Font-Fallback: %1$@"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo preparar paquete de fuentes abiertas; lanzamiento continuo sin respaldo de fuente adicional: %1$@"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "pack de polices libres n'a pas pu être préparé ; lancement continu sans remplacement de police supplémentaire : %1$@"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "オープンフォントパック を準備できませんでした。追加のフォント フォールバックなしで起動を続行: %1$@"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "오픈 폰트 팩을 준비하지 못했습니다. 추가 글꼴 대체 없이 앱을 계속 실행합니다: %1$@"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Não foi possível preparar o pacote de fontes abertas. O aplicativo será aberto sem fontes alternativas adicionais: %1$@"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "пакет открытых шрифтов не удалось подготовить; продолжение запуска без дополнительного резервного шрифта: %1$@"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "开放字体包 无法准备；继续发布，无需额外的字体后备：%1$@"
          }
