    },
    "The log entries shown for %@ will be removed from Switchyard.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die für %1$@ angezeigten Protokolleinträge werden aus Switchyard entfernt."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las entradas de registro que se muestran para %1$@ se eliminarán de Switchyard."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les entrées de journal affichées pour %1$@ seront supprimées de Switchyard."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ に表示されるログ エントリは、Switchyard から削除されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@에 대해 표시된 로그 항목은 Switchyard에서 제거됩니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "As entradas de log exibidas para %1$@ serão removidas do Switchyard."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Записи журнала, показанные для %1$@, будут удалены из Switchyard."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ 显示的日志条目将从 Switchyard 中删除。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ 顯示的日誌條目將從 Switchyard 中刪除。"
          }
        }
      }
    },
    "The log entries shown in Switchyard will be removed. Debug run files keep their configured retention period.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die in Switchyard angezeigten Protokolleinträge werden entfernt. Debug-Laufdateien behalten ihren konfigurierten Aufbewahrungszeitraum."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se eliminarán las entradas de registro que se muestran en Switchyard. Los archivos de ejecución de depuración mantienen su período de retención configurado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les entrées de journal affichées dans Switchyard seront supprimées. Les fichiers d’exécution de débogage conservent leur période de conservation configurée."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard に表示されるログ エントリは削除されます。デバッグ実行ファイルは、設定された保存期間を維持します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard 화면의 로그 항목을 지웁니다. 디버그 실행 파일은 설정된 보관 기간 동안 그대로 둡니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "As entradas de registro mostradas em Switchyard serão removidas. Os arquivos de execução de depuração mantêm o período de retenção configurado."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Записи журнала, показанные в Switchyard, будут удалены. Файлы запуска отладки сохраняют настроенный срок хранения."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard 中显示的日志条目将被删除。调试运行文件保留其配置的保留期。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard 中顯示的日誌條目將會被刪除。調試運行檔案保留其配置的保留期。"
          }
        }
      }
    },
    "The main runtime download is about 700 MB. Switchyard checks its size, fingerprint, developer signature, and Apple notarization before using it.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Haupt-Runtime-Download ist etwa 700 MB groß. Switchyard überprüft vor der Verwendung Größe, Fingerabdruck, Entwicklersignatur und Apple-Beglaubigung."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La descarga del tiempo de ejecución principal es de aproximadamente 700 MB. Switchyard verifica su tamaño, huella digital, firma del desarrollador y certificación notarial de Apple antes de usarlo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le téléchargement du runtime principal fait environ 700 Mo. Switchyard vérifie sa taille, son empreinte digitale, la signature du développeur et la notarisation Apple avant de l'utiliser."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "メインのランタイムのダウンロードは約 700 MB です。 Switchyard は、使用前にサイズ、指紋、開発者の署名、Apple の公証をチェックします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "기본 런타임 다운로드 크기는 약 700MB입니다. Switchyard는 사용 전 크기, 지문, 개발자 서명, Apple 공증 등을 확인합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O download principal do runtime tem cerca de 700 MB. Antes de usá-lo, o Switchyard verifica o tamanho, a impressão digital, a assinatura do desenvolvedor e a notarização da Apple."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Основная загрузка во время выполнения составляет около 700 МБ. Перед использованием Switchyard проверяет свой размер, отпечаток пальца, подпись разработчика и нотариальное заверение Apple."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "主要运行时下载约为 700 MB。 Switchyard 在使用前检查其大小、指纹、开发者签名和 Apple 公证。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "主要運行時下載約為 700 MB。 Switchyard 在使用前檢查其大小、指紋、開發者簽名和 Apple 公證。"
          }
        }
      }
    },
    "The release metadata is incomplete.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Veröffentlichungsmetadaten sind unvollständig."
