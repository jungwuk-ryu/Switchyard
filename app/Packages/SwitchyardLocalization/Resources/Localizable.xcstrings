            "state": "translated",
            "value": "移除运行时前，请等待所有容器任务结束。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "移除執行環境前，請等待所有容器工作結束。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ランタイムを削除する前に、すべてのコンテナ処理が終了するまでお待ちください。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Перед удалением среды выполнения дождитесь завершения всех операций с контейнерами."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Warten Sie, bis alle Containeraktivitäten beendet sind, bevor Sie eine Laufzeitumgebung entfernen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Attendez la fin de toute activité des conteneurs avant de supprimer un environnement."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Espera a que termine toda la actividad de los contenedores antes de eliminar un entorno."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Aguarde o término de todas as atividades dos contêineres antes de remover um runtime."
          }
        }
      }
    },
    "Wait for compatibility setup to finish before starting a Windows app.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Windows 앱을 시작하기 전에 호환성 설정이 끝날 때까지 기다리세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请等待兼容性设置完成后再启动 Windows 应用。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "請等待相容性設定完成後再啟動 Windows App。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Windows アプリを起動する前に、互換性設定が完了するまで待ってください。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Дождитесь завершения настройки совместимости, прежде чем запускать приложение Windows."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Warten Sie, bis die Kompatibilitätseinrichtung abgeschlossen ist, bevor Sie eine Windows-App starten."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Attendez la fin de la configuration de compatibilité avant de lancer une app Windows."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Espera a que finalice la configuración de compatibilidad antes de iniciar una app de Windows."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Aguarde a conclusão da configuração de compatibilidade antes de iniciar um app do Windows."
          }
        }
      }
    },
    "Wait for the container folder operation to finish before recovering a login callback.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Warten Sie, bis der Containerordnervorgang abgeschlossen ist, bevor Sie einen Anmelderückruf wiederherstellen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Espere a que finalice la operación de la carpeta contenedora antes de recuperar una devolución de llamada de inicio de sesión."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Attendez la fin de l'opération sur le dossier conteneur avant de récupérer un rappel de connexion."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "コンテナ フォルダの操作が完了するまで待ってから、ログイン コールバックを回復します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "컨테이너 폴더 작업이 끝난 뒤 로그인을 다시 시도하세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Espere a operação da pasta do contêiner terminar antes de recuperar um callback de início de sessão."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Дождитесь завершения операции с папкой контейнера, прежде чем восстанавливать обратный вызов входа в систему."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "等待容器文件夹操作完成，然后再恢复登录回调。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "等待容器資料夾操作完成，然後再恢復登入回呼。"
          }
        }
      }
    },
    "Wait for the current Steam setup to finish, or stop it before trying again.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Warten Sie, bis das aktuelle Steam-Setup abgeschlossen ist, oder stoppen Sie es, bevor Sie es erneut versuchen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Espere a que finalice la configuración actual de Steam o deténgala antes de volver a intentarlo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Attendez la fin de la configuration actuelle du Steam ou arrêtez-la avant de réessayer."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "現在の Steam セットアップが完了するまで待つか、再試行する前に停止してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "현재 Steam 설정이 완료될 때까지 기다리거나 다시 시도하기 전에 중지하세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Espere a configuração Steam atual terminar, ou pare antes de tentar novamente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Подождите, пока текущая установка Steam завершится, или остановите ее, прежде чем повторить попытку."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "等待当前的 Steam 设置完成，或停止它，然后重试。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "等待目前的 Steam 設定完成，或停止它，然後重試。"
          }
        }
      }
    },
