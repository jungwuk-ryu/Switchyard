    },
    "This app build does not trust the Developer ID team that signed the runtime.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 앱 빌드는 런타임에 서명한 Developer ID 팀을 신뢰하지 않습니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此应用构建不信任签署该运行时的 Developer ID 团队。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "此 App 建置版本不信任簽署該執行環境的 Developer ID 團隊。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このアプリビルドは、ランタイムに署名した Developer ID チームを信頼していません。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Эта сборка приложения не доверяет команде Developer ID, подписавшей среду выполнения."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dieser App-Build vertraut dem Developer-ID-Team nicht, das die Laufzeitumgebung signiert hat."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ce build de l’app ne fait pas confiance à l’équipe Developer ID qui a signé l’environnement d’exécution."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
