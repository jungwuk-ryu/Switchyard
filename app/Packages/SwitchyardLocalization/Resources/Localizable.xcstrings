          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "剪貼簿不包含受支援的自訂回調 URL。"
          }
        }
      }
    },
    "The compatibility runtime and Apple's graphics support are ready. You can now install a Windows app.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Kompatibilitätslaufzeit und die Grafikunterstützung von Apple sind bereit. Sie können jetzt eine Windows-App installieren."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El tiempo de ejecución de compatibilidad y el soporte de gráficos de Apple están listos. Ahora puede instalar una aplicación Windows."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le runtime de compatibilité et le support graphique d'Apple sont prêts. Vous pouvez maintenant installer une application Windows."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "互換性ランタイムと Apple のグラフィックス サポートが準備されています。 Windows アプリをインストールできるようになりました。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "호환성 런타임과 Apple의 그래픽 지원이 준비되었습니다. 이제 Windows 앱을 설치할 수 있습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O runtime de compatibilidade e o suporte gráfico da Apple estão prontos. Agora você pode instalar um app do Windows."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Среда совместимости и поддержка графики Apple готовы. Теперь вы можете установить приложение Windows."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "兼容性运行时和 Apple 的图形支持已准备就绪。您现在可以安装 Windows 应用程序。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "相容性運行時和 Apple 的圖形支援已準備就緒。現在您可以安裝 Windows 應用程式。"
          }
        }
      }
    },
