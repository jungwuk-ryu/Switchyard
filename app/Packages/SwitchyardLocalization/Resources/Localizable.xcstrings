          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La ubicación de almacenamiento y las rutas técnicas se eligen automáticamente. Puedes cambiarlas en «Opciones avanzadas»."
          }
        },
        "fr": {
          "stringUnit": {
