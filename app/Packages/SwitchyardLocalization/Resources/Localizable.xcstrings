    "Only .dmg disk images can be imported automatically.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nur .dmg-Disk-Images können automatisch importiert werden."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sólo las imágenes de disco .dmg se pueden importar automáticamente."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Seules les images disque .dmg peuvent être importées automatiquement."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "自動的にインポートできるのは、.dmg ディスク イメージのみです。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": ".dmg 디스크 이미지만 자동으로 가져올 수 있습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Somente imagens de disco .dmg podem ser importadas automaticamente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Автоматически можно импортировать только образы дисков .dmg."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "仅 .dmg 磁盘映像可以自动导入。"
          }
