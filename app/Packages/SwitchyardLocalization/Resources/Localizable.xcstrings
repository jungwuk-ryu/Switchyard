    "Continue in the same private container; Switchyard will not create a duplicate.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Fahren Sie im selben privaten Container fort; Switchyard erstellt kein Duplikat."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Continuar en el mismo contenedor privado; Switchyard no creará un duplicado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Continuez dans le même conteneur privé ; Switchyard ne créera pas de doublon."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "同じプライベートコンテナ内で続行します。 Switchyard は重複を作成しません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "동일한 개인 컨테이너에서 계속하십시오. Switchyard는 중복을 생성하지 않습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Continue no mesmo contêiner privado; Switchyard não vai criar uma duplicata."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Продолжайте в том же личном контейнере; Switchyard не будет создавать дубликат."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "继续在同一个私人容器中； Switchyard 不会创建重复项。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "繼續在同一個私人容器中； Switchyard 不會建立重複項。"
          }
        }
      }
    },
