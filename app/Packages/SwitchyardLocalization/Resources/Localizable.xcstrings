          "stringUnit": {
            "state": "translated",
            "value": "下載的檔案不是完整的 Windows Steam 安裝程式。"
          }
        }
      }
    },
    "The downloaded runtime checksum does not match its release manifest.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die heruntergeladene Laufzeitprüfsumme stimmt nicht mit dem Release-Manifest überein."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La suma de comprobación del tiempo de ejecución descargada no coincide con su manifiesto de lanzamiento."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La somme de contrôle d'exécution téléchargée ne correspond pas à son manifeste de version."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ダウンロードされたランタイム チェックサムがリリース マニフェストと一致しません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "다운로드한 런타임 체크섬이 릴리스 매니페스트와 일치하지 않습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A soma de verificação do runtime baixado não corresponde ao manifesto da versão."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Загруженная контрольная сумма среды выполнения не соответствует манифесту выпуска."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "下载的运行时校验和与其发布清单不匹配。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "下載的運行時校驗和與其發布清單不符。"
          }
        }
      }
    },
    "The downloaded runtime size does not match its release manifest.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die heruntergeladene Laufzeitgröße stimmt nicht mit dem Release-Manifest überein."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El tamaño del tiempo de ejecución descargado no coincide con su manifiesto de lanzamiento."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La taille du runtime téléchargé ne correspond pas à son manifeste de version."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ダウンロードされたランタイムのサイズがリリース マニフェストと一致しません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "다운로드한 런타임 크기가 릴리스 매니페스트와 일치하지 않습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O tamanho do runtime baixado não corresponde ao manifesto da versão."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Размер загруженной среды выполнения не соответствует манифесту выпуска."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "下载的运行时大小与其发布清单不匹配。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "下載的運行時大小與其發布清單不符。"
          }
        }
