        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O runtime pode ser executado, mas não foi possível verificar a identidade do código-fonte."
          }
        }
      }
    },
    "The runtime release does not match this app's compatible source revision.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Laufzeitversion stimmt nicht mit der kompatiblen Quellrevision dieser App überein."
          }
        },
