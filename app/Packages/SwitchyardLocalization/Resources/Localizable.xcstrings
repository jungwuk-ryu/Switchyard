          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "최신 온라인 런타임은 이 앱에서 검증한 호환 범위를 벗어납니다. 설치하기 전에 Switchyard를 업데이트해 현재 승인된 런타임을 받으세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O runtime online mais recente está fora da política de compatibilidade verificada deste app. Atualize o Switchyard para obter o runtime aprovado antes de instalar."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Новейшая онлайн-версия среды выполнения не входит в проверенный диапазон совместимости этого приложения. Перед установкой обновите Switchyard, чтобы получить одобренную среду выполнения."
          }
