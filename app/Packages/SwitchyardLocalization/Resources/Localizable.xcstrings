            "state": "translated",
            "value": "相容性待定"
          }
        }
      }
    },
    "Compatibility files cannot be changed while a Windows app is still running.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Kompatibilitätsdateien können nicht geändert werden, während eine Windows-App noch ausgeführt wird."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los archivos de compatibilidad no se pueden cambiar mientras una aplicación Windows aún se está ejecutando."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les fichiers de compatibilité ne peuvent pas être modifiés lorsqu'une application Windows est toujours en cours d'exécution."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Windows アプリの実行中は、互換性ファイルを変更できません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Windows 앱이 실행되는 동안에는 호환성 파일을 변경할 수 없습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Arquivos de compatibilidade não podem ser alterados enquanto um aplicativo Windows estiver rodando."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Файлы совместимости нельзя изменить, пока приложение Windows все еще работает."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当 Windows 应用程序仍在运行时，无法更改兼容性文件。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "當 Windows 應用程式仍在運行時，無法變更相容性檔案。"
          }
        }
      }
    },
