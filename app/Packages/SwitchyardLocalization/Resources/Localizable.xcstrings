          "stringUnit": {
            "state": "translated",
            "value": "Rosetta 2 est requis pour le runtime de compatibilité Windows."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Rosetta 2 は、Windows 互換ランタイムに必要です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Rosetta 2는 Windows 호환성 런타임에 필요합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
