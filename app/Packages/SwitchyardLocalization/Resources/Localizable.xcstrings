    "The first-run container preparation did not finish; the app will still open and Wine can retry automatically: %@": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Vorbereitung des ersten Containers wurde nicht abgeschlossen. Die App wird weiterhin geöffnet und Wine kann es automatisch erneut versuchen: %1$@"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
