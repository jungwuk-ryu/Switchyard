    },
    "A newer Switchyard release recommends the latest runtime. Other signed official versions remain available under Wine Runtime settings.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "새 Switchyard 릴리스에서는 최신 런타임을 권장합니다. 서명된 다른 공식 버전은 Wine 런타임 설정에서 선택할 수 있습니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "新版 Switchyard 建议使用最新运行时。你仍可在“Wine 运行时”设置中选择其他已签名的官方版本。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "新版 Switchyard 建議使用最新的執行環境。你仍可在「Wine 執行環境」設定中選擇其他已簽署的官方版本。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "新しい Switchyard リリースでは最新のランタイムが推奨されています。署名済みのほかの公式バージョンは「Wine ランタイム」設定から選択できます。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Новая версия Switchyard рекомендует последнюю среду выполнения. Другие подписанные официальные версии доступны в настройках среды выполнения Wine."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Eine neuere Switchyard-Version empfiehlt die aktuelle Laufzeitumgebung. Andere signierte offizielle Versionen bleiben in den Wine-Laufzeiteinstellungen verfügbar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Une version plus récente de Switchyard recommande le dernier environnement d’exécution. Les autres versions officielles signées restent disponibles dans les réglages de l’environnement Wine."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Una versión más reciente de Switchyard recomienda el último entorno de ejecución. Las demás versiones oficiales firmadas siguen disponibles en los ajustes del entorno de Wine."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Uma versão mais recente do Switchyard recomenda o runtime mais atual. Outras versões oficiais assinadas continuam disponíveis nos ajustes do runtime do Wine."
          }
        }
      }
    },
