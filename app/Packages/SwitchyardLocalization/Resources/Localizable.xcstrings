    "Login callback recovery was cancelled because the container folder is changing.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Wiederherstellung des Anmelderückrufs wurde abgebrochen, da sich der Containerordner ändert."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La recuperación de devolución de llamada de inicio de sesión se canceló porque la carpeta del contenedor está cambiando."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La récupération du rappel de connexion a été annulée car le dossier du conteneur est en train de changer."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "コンテナ フォルダが変更中であるため、ログイン コールバックの回復がキャンセルされました。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "컨테이너 폴더를 변경하는 중이라 로그인 복구를 취소했습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A recuperação do callback de início de sessão foi cancelada porque a pasta do contêiner está sendo alterada."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Восстановление обратного вызова для входа было отменено, поскольку папка контейнера изменилась."
