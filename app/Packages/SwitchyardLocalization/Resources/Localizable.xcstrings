    "Preparing this Windows container for the active Switchyard runtime.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "활성 Switchyard 런타임에 맞게 이 Windows 컨테이너를 준비하는 중입니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "正在为活动的 Switchyard 运行时准备此 Windows 容器。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "正在針對使用中的 Switchyard 執行環境準備此 Windows 容器。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アクティブな Switchyard ランタイム向けにこの Windows コンテナを準備しています。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Подготовка этого контейнера Windows для активной среды выполнения Switchyard."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dieser Windows-Container wird für die aktive Switchyard-Laufzeitumgebung vorbereitet."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Préparation de ce conteneur Windows pour l’environnement d’exécution actif de Switchyard."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Preparando este contenedor de Windows para el entorno de ejecución activo de Switchyard."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Preparando este contêiner do Windows para o runtime ativo do Switchyard."
          }
        }
      }
    },
    "Press Return or leave the field to rename the container and its folder": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Drücken Sie die Eingabetaste oder verlassen Sie das Feld, um den Container und seinen Ordner umzubenennen"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Presione Retorno o abandone el campo para cambiar el nombre del contenedor y su carpeta."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Appuyez sur Retour ou quittez le champ pour renommer le conteneur et son dossier"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Return キーを押すか、フィールドを離れてコンテナとそのフォルダの名前を変更します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "컨테이너와 해당 폴더의 이름을 바꾸려면 Return 키를 누르거나 필드를 떠나세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Pressione Retorno ou saia do campo para renomear o contêiner e sua pasta"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Нажмите Return или оставьте поле, чтобы переименовать контейнер и его папку."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "按 Return 或保留该字段以重命名容器及其文件夹"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "按 Return 或保留該欄位以重新命名容器及其資料夾"
          }
        }
      }
    },
