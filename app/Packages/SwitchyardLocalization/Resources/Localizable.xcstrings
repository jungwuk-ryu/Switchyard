    "The runtime is runnable, but it does not match this version of Switchyard. Install the compatible runtime to continue.": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Laufzeit ist lauffähig, entspricht jedoch nicht dieser Version von Switchyard. Installieren Sie die kompatible Laufzeit, um fortzufahren."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El tiempo de ejecución se puede ejecutar, pero no coincide con esta versión de Switchyard. Instale el tiempo de ejecución compatible para continuar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le runtime est exécutable, mais il ne correspond pas à cette version de Switchyard. Installez le runtime compatible pour continuer."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ランタイムは実行可能ですが、このバージョンの Switchyard と一致しません。続行するには、互換性のあるランタイムをインストールしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "런타임은 실행 가능하지만 이 버전의 Switchyard와 일치하지 않습니다. 계속하려면 호환 가능한 런타임을 설치하세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O runtime pode ser executado, mas não corresponde a esta versão do Switchyard. Instale o runtime compatível para continuar."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Среда выполнения работоспособна, но она не соответствует этой версии Switchyard. Установите совместимую среду выполнения, чтобы продолжить."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "运行时可以运行，但与此版本的 Switchyard 不匹配。安装兼容的运行时以继续。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "運行時可以運行，但與此版本的 Switchyard 不符。安裝相容的運行時以繼續。"
          }
        }
      }
    },
    "The runtime is runnable, but its source identity could not be verified.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "런타임을 실행할 수 있지만 소스 ID를 확인할 수 없습니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
