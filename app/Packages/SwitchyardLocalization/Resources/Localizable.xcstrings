          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "執行環境可以執行，但無法驗證其來源身分。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ランタイムは実行できますが、ソースの識別情報を検証できませんでした。"
