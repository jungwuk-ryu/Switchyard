        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "請等待所有容器活動停止後再變更 GPTK。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "GPTK を変更する前に、すべてのコンテナの処理が停止するまで待ってください。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Дождитесь завершения всех операций с контейнерами, прежде чем менять GPTK."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Warten Sie, bis alle Containeraktivitäten beendet sind, bevor Sie GPTK ändern."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Attendez la fin de toute activité des conteneurs avant de modifier GPTK."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Espera a que finalice toda la actividad de los contenedores antes de cambiar GPTK."
          }
        },
        "pt-BR": {
          "stringUnit": {
