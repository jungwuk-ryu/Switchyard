    "Open Font Pack is missing %lld OFL font file(s). Switchyard will try to download them automatically.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Open-Font-Paket fehlt die Schriftartdatei(en) %1$lld OFL. Switchyard wird versuchen, sie automatisch herunterzuladen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "A paquete de fuentes abiertas le faltan archivos de fuentes %1$lld OFL. Switchyard intentará descargarlos automáticamente."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "pack de polices libres ne contient pas de fichier(s) de police %1$lld OFL. Switchyard tentera de les télécharger automatiquement."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "オープンフォントパック には、%1$lld OFL フォント ファイルがありません。 Switchyard はそれらを自動的にダウンロードしようとします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "오픈 폰트 팩에 %1$lld OFL 글꼴 파일이 없습니다. Switchyard는 자동으로 다운로드를 시도합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Faltam %1$lld arquivos de fonte OFL no pacote de fontes abertas. O Switchyard tentará baixá-los automaticamente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "В пакет открытых шрифтов отсутствуют файлы шрифтов %1$lld OFL. Switchyard попытается загрузить их автоматически."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "开放字体包 缺少 %1$lld OFL 字体文件。 Switchyard 将尝试自动下载它们。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "開放字型套件 缺少 %1$lld OFL 字型檔。 Switchyard 將嘗試自動下載它們。"
          }
        }
      }
    },
    "Open Font Pack registration was skipped while this Windows session is active.": {
