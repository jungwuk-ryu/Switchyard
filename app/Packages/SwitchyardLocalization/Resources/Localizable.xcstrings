          "stringUnit": {
            "state": "translated",
            "value": "僅 .dmg 磁碟映像可以自動匯入。"
          }
        }
      }
    },
    "Only the Switchyard-managed runtime cache will be deleted.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Switchyard에서 관리하는 런타임 캐시만 삭제됩니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "只会删除由 Switchyard 管理的运行时缓存。"
