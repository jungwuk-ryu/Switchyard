    "%@ checksum mismatch. Expected %@, got %@.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ Prüfsummenkonflikt. %2$@ erwartet, %3$@ erhalten."
          }
        },
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@ checksum mismatch. Expected %2$@, got %3$@."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ no coincide con la suma de comprobación. Se esperaba %2$@, obtuve %3$@."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Incompatibilité de somme de contrôle %1$@. %2$@ attendu, obtenu %3$@."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ チェックサムが一致しません。 %2$@ を期待していましたが、%3$@ を取得しました。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ 체크섬 불일치. %2$@를 예상했지만 %3$@를 받았습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A soma de verificação de %1$@ não corresponde. Esperado: %2$@; obtido: %3$@."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ несоответствие контрольной суммы. Ожидал %2$@, получил %3$@."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ 校验和不匹配。预期为 %2$@，得到 %3$@。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ 校驗和不符。預期為 %2$@，得到 %3$@。"
          }
        }
      }
    },
    "%@ contains GPTK markers, but its executable code is not fully Apple-signed: %@": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ enthält GPTK-Marker, aber sein ausführbarer Code ist nicht vollständig von Apple signiert: %2$@"
          }
        },
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@ contains GPTK markers, but its executable code is not fully Apple-signed: %2$@"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ contiene marcadores GPTK, pero su código ejecutable no está completamente firmado por Apple: %2$@"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ contient des marqueurs GPTK, mais son code exécutable n'est pas entièrement signé par Apple : %2$@"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ には GPTK マーカーが含まれていますが、その実行可能コードは完全に Apple 署名されていません: %2$@"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@에 GPTK 마커는 있지만, 실행 코드 일부의 Apple 서명을 확인할 수 없습니다: %2$@"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ contém marcadores do GPTK, mas o código executável não está totalmente assinado pela Apple: %2$@"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ содержит маркеры GPTK, но его исполняемый код не полностью подписан Apple: %2$@"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ 包含 GPTK 标记，但其可执行代码未完全经过 Apple 签名：%2$@"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ 包含 GPTK 標記，但其可執行程式碼未完全經過 Apple 簽署：%2$@"
          }
        }
      }
    },
    "%@ exists, but no known D3DMetal/GPTK marker files were found.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ existiert, aber es wurden keine bekannten D3DMetal/GPTK-Markierungsdateien gefunden."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ existe, pero no se encontraron archivos de marcadores D3DMetal/GPTK conocidos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ existe, mais aucun fichier de marqueur D3DMetal/GPTK connu n'a été trouvé."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ は存在しますが、既知の D3DMetal/GPTK マーカー ファイルが見つかりませんでした。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@가 존재하지만 알려진 D3DMetal/GPTK 마커 파일을 찾을 수 없습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ existe, mas nenhum arquivo de marcadores D3DMetal/GPTK conhecidos foi encontrado."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ существует, но известные файлы маркеров D3DMetal/GPTK не найдены."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ 存在，但未找到已知的 D3DMetal/GPTK 标记文件。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ 存在，但找不到已知的 D3DMetal/GPTK 標記檔。"
          }
        }
      }
    },
