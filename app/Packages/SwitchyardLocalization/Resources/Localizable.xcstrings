        }
      }
    },
    "The clipboard does not contain a supported custom callback URL.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Zwischenablage enthält keine unterstützte benutzerdefinierte Rückruf-URL."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El portapapeles no contiene una URL de devolución de llamada personalizada compatible."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le presse-papiers ne contient pas d'URL de rappel personnalisée prise en charge."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "クリップボードには、サポートされているカスタム コールバック URL が含まれていません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "클립보드에 지원되는 사용자 정의 콜백 URL이 없습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A área de transferência não contém uma URL de callback personalizada suportada."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Буфер обмена не содержит поддерживаемого пользовательского URL-адреса обратного вызова."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
