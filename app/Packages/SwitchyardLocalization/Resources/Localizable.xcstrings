          }
        }
      }
    },
    "Open Font Pack is already cached with %lld font files.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Open-Font-Paket ist bereits mit den Schriftartdateien %1$lld zwischengespeichert."
          }
        },
        "es": {
