        }
      }
    },
    "The download is ready. Switchyard will verify Apple's signature before importing it.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Download ist fertig. Switchyard überprüft die Signatur von Apple vor dem Import."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La descarga está lista. Switchyard verificará la firma de Apple antes de importarla."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le téléchargement est prêt. Switchyard vérifiera la signature d'Apple avant de l'importer."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ダウンロードの準備ができました。 Switchyard は、インポートする前に Apple の署名を検証します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "다운로드가 준비되었습니다. Switchyard는 Apple의 서명을 가져오기 전에 확인합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O download está pronto. Switchyard vai verificar a assinatura da Apple antes de importar."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Загрузка готова. Switchyard проверит подпись Apple перед ее импортом."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "下载已准备就绪。 Switchyard在导入之前会验证Apple的签名。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "下載已準備就緒。 Switchyard在導入前會先驗證Apple的簽章。"
          }
        }
      }
    },
    "The download left the official Valve download service, so Switchyard stopped it.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Download hat den offiziellen Valve-Downloaddienst verlassen, also hat Switchyard ihn gestoppt."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La descarga salió del servicio de descarga oficial Valve, por lo que Switchyard la detuvo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le téléchargement a quitté le service de téléchargement officiel Valve, donc Switchyard l'a arrêté."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ダウンロードにより公式の Valve ダウンロード サービスが終了したため、Switchyard がサービスを停止しました。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "다운로드가 공식 Valve 다운로드 서비스를 떠났기 때문에 Switchyard가 이를 중지했습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O download saiu do serviço oficial da Valve e foi interrompido pelo Switchyard."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Загрузка вышла из официальной службы загрузки Valve, поэтому Switchyard остановил ее."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "该下载离开了官方Valve下载服务，因此Switchyard停止了它。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "該下載離開了官方Valve下載服務，因此Switchyard停止了它。"
          }
        }
      }
    },
    "The download was unexpectedly large, so Switchyard stopped before using it.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Download war unerwartet groß, daher stoppte Switchyard vor der Verwendung."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La descarga fue inesperadamente grande, por lo que Switchyard se detuvo antes de usarla."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le téléchargement était étonnamment volumineux, donc Switchyard s'est arrêté avant de l'utiliser."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ダウンロードが予想外に大きかったため、Switchyard は使用する前に停止しました。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "다운로드 용량이 예상외로 커서 Switchyard를 사용하기 전에 중지했습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O download foi inesperadamente grande, então Switchyard parou antes de usá-lo."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Загрузка оказалась неожиданно большой, поэтому Switchyard остановился перед ее использованием."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "下载量出乎意料地大，因此 Switchyard 在使用之前停止了。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "下載量出乎意料地大，因此 Switchyard 在使用之前停止了。"
          }
        }
      }
    },
    "The downloaded file is not a complete Windows Steam installer.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die heruntergeladene Datei ist kein vollständiges Windows Steam-Installationsprogramm."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
