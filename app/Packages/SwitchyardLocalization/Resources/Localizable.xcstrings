    },
    "A different GPTK import already exists at the immutable destination.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Am unveränderlichen Ziel ist bereits ein anderer GPTK-Import vorhanden."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ya existe una importación GPTK diferente en el destino inmutable."
          }
