    "%@ in the Open Font Pack cache failed checksum validation. Expected %@, got %@.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Bei %1$@ im Open-Font-Paket-Cache ist die Prüfsummenvalidierung fehlgeschlagen. %2$@ erwartet, %3$@ erhalten."
          }
        },
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@ in the Open Font Pack cache failed checksum validation. Expected %2$@, got %3$@."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ en la caché paquete de fuentes abiertas falló en la validación de la suma de comprobación. Se esperaba %2$@, obtuve %3$@."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ dans le cache pack de polices libres a échoué à la validation de la somme de contrôle. %2$@ attendu, obtenu %3$@."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "オープンフォントパック キャッシュの %1$@ がチェックサム検証に失敗しました。 %2$@ を期待していましたが、%3$@ を取得しました。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "오픈 폰트 팩 캐시의 %1$@가 체크섬 검증에 실패했습니다. %2$@를 예상했지만 %3$@를 받았습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ no cache do pacote de fontes abertas falhou na verificação. Esperado: %2$@; obtido: %3$@."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ в кэше пакет открытых шрифтов не прошел проверку контрольной суммы. Ожидал %2$@, получил %3$@."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "开放字体包 缓存中的 %1$@ 校验和验证失败。预期为 %2$@，得到 %3$@。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "開放字型套件 快取中的 %1$@ 校驗和驗證失敗。預期為 %2$@，得到 %3$@。"
          }
        }
      }
    },
    "%@ is already running": {
      "localizations": {
