    "Container names cannot be empty.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Containernamen dürfen nicht leer sein."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los nombres de los contenedores no pueden estar vacíos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les noms de conteneurs ne peuvent pas être vides."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "コンテナ名を空にすることはできません。"
          }
        },
        "ko": {
