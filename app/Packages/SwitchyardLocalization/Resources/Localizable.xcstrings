    "If Safari says the address is invalid after signing in, press Command-L and Command-C in Safari, then recover the copied callback here.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenn Safari nach der Anmeldung meldet, dass die Adresse ungültig ist, drücken Sie in Safari Befehl-L und Befehl-C und stellen Sie dann den kopierten Rückruf hier wieder her."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Si Safari dice que la dirección no es válida después de iniciar sesión, presione Comando-L y Comando-C en Safari, luego recupere la devolución de llamada copiada aquí."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Si Safari indique que l'adresse n'est pas valide après la connexion, appuyez sur Commande-L et Commande-C dans Safari, puis récupérez le rappel copié ici."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "サインイン後に Safari でアドレスが無効であると表示された場合は、Safari で Command-L キーと Command-C キーを押して、ここでコピーしたコールバックを復元します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "로그인 후 Safari가 앱으로 돌아가지 못하면 주소를 복사해 여기서 다시 시도하세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Se o Safari disser que o endereço é inválido após o login, pressione Command-L e Command-C no Safari, e então recupere a chamada copiada aqui."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Если после входа в систему Safari сообщает, что адрес недействителен, нажмите Command-L и Command-C в Safari, а затем восстановите скопированный обратный вызов здесь."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "如果登录后 Safari 提示地址无效，请在 Safari 中按 Command-L 和 Command-C，然后在此处恢复复制的回调。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "如果登入後 Safari 提示位址無效，請在 Safari 中按 Command-L 和 Command-C，然後在此處還原複製的回呼。"
          }
        }
      }
    },
