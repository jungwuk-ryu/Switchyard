            "state": "translated",
            "value": "發行版本中繼資料不完整。"
          }
        }
      }
    },
    "The runtime archive contains a symbolic link outside its installation directory.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das Laufzeitarchiv enthält einen symbolischen Link außerhalb seines Installationsverzeichnisses."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El archivo de ejecución contiene un enlace simbólico fuera de su directorio de instalación."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'archive d'exécution contient un lien symbolique en dehors de son répertoire d'installation."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ランタイム アーカイブには、インストール ディレクトリの外にシンボリック リンクが含まれています。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "런타임 아카이브에 설치 디렉터리 밖을 가리키는 심볼릭 링크가 있습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O arquivo do runtime contém um link simbólico que aponta para fora da pasta de instalação."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Архив времени выполнения содержит символическую ссылку вне каталога установки."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "运行时存档在其安装目录之外包含一个符号链接。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "運行時存檔在其安裝目錄之外包含一個符號連結。"
          }
        }
      }
    },
    "The runtime archive contains an unsafe entry: %@": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das Laufzeitarchiv enthält einen unsicheren Eintrag: %1$@"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
