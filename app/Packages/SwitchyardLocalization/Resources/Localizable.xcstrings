    "All Windows apps in %@ will close. Unsaved work may be lost.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Alle Windows-Apps in %1$@ werden geschlossen. Nicht gespeicherte Arbeiten gehen möglicherweise verloren."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se cerrarán todas las aplicaciones Windows en %1$@. Es posible que se pierda el trabajo no guardado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Toutes les applications Windows dans %1$@ se fermeront. Le travail non enregistré peut être perdu."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ 内のすべての Windows アプリが終了します。保存されていない作業内容は失われる可能性があります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@의 모든 Windows 앱이 종료됩니다. 저장하지 않은 작업은 손실될 수 있습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Todos os aplicativos do Windows em %1$@ serão fechados. Alterações não salvas poderão ser perdidas."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Все приложения Windows в %1$@ закроются. Несохраненная работа может быть потеряна."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ 中的所有 Windows 应用程序都将关闭。未保存的工作可能会丢失。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ 中的所有 Windows 應用程式都將關閉。未儲存的工作可能會遺失。"
          }
        }
      }
    },
    "Allow about 5–15 minutes and roughly 1 GB of free space. Download time depends on your connection.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Planen Sie etwa 5–15 Minuten und etwa 1 GB freien Speicherplatz ein. Die Downloadzeit hängt von Ihrer Verbindung ab."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Espere entre 5 y 15 minutos y aproximadamente 1 GB de espacio libre. El tiempo de descarga depende de su conexión."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Attendez environ 5 à 15 minutes et environ 1 Go d'espace libre. Le temps de téléchargement dépend de votre connexion."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "約 5 ～ 15 分かかり、約 1 GB の空き容量が必要になります。ダウンロード時間は接続によって異なります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "약 5~15분 정도의 여유 공간과 약 1GB의 여유 공간을 확보하세요. 다운로드 시간은 연결 상태에 따라 다릅니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Permita cerca de 5 a 15 minutos e aproximadamente 1 GB de espaço livre. O tempo de download depende da sua conexão."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выделите около 5–15 минут и примерно 1 ГБ свободного места. Время загрузки зависит от вашего соединения."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "需要大约 5-15 分钟和大约 1 GB 的可用空间。下载时间取决于您的连接。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "需要大約 5-15 分鐘和大約 1 GB 的可用空間。下載時間取決於您的連線。"
          }
        }
      }
    },
    "Another runtime installation is already in progress.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Eine weitere Laufzeitinstallation ist bereits in Bearbeitung."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ya se está realizando otra instalación en tiempo de ejecución."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Une autre installation du runtime est déjà en cours."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "別のランタイムのインストールがすでに進行中です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "다른 런타임 설치가 이미 진행 중입니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Já há outra instalação do runtime em andamento."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Другая установка среды выполнения уже выполняется."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "另一个运行时安装已经在进行中。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "另一個運行時安裝已經在進行中。"
          }
        }
      }
    },
    "Any remaining Windows processes for %@ will be stopped before its folder is moved to Trash.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Alle verbleibenden Windows-Prozesse für %1$@ werden gestoppt, bevor der Ordner in den Papierkorb verschoben wird."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cualquier proceso restante de Windows para %1$@ se detendrá antes de que su carpeta se mueva a la Papelera."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tous les processus Windows restants pour %1$@ seront arrêtés avant que son dossier ne soit déplacé vers la corbeille."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ の残りの Windows プロセスは、フォルダーがゴミ箱に移動される前に停止されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@의 폴더를 휴지통으로 옮기기 전에 남아 있는 Windows 프로세스를 모두 중지합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Quaisquer processos Windows restantes para %1$@ serão interrompidos antes que sua pasta seja movida para a Lixeira."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Все оставшиеся процессы Windows для %1$@ будут остановлены до того, как его папка будет перемещена в корзину."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ 的任何剩余 Windows 进程都将在其文件夹移至垃圾箱之前停止。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ 的任何剩餘 Windows 進程都將在其資料夾移至垃圾箱之前停止。"
          }
        }
      }
    },
