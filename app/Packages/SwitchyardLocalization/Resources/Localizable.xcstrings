    "Wait for all container activity to stop before removing a runtime.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "런타임을 제거하기 전에 모든 컨테이너 작업이 끝날 때까지 기다리세요."
          }
        },
        "zh-Hans": {
