    "Rosetta 2 is required for the Windows compatibility runtime.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Rosetta 2 ist für die Kompatibilitätslaufzeit Windows erforderlich."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se requiere Rosetta 2 para el tiempo de ejecución de compatibilidad Windows."
          }
        },
