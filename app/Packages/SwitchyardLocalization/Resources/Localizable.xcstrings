    "Keep the Windows game open while recovering its copied login callback.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Lassen Sie das Spiel Windows geöffnet, während der kopierte Anmelderückruf wiederhergestellt wird."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantenga abierto el juego Windows mientras recupera la devolución de llamada de inicio de sesión copiada."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Gardez le jeu Windows ouvert tout en récupérant son rappel de connexion copié."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "コピーされたログイン コールバックを回復している間、Windows ゲームを開いたままにします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "로그인 복구가 끝날 때까지 Windows 앱을 열어 두세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantenha o jogo Windows aberto enquanto recupera o retorno de login copiado."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Оставьте игру Windows открытой, пока восстанавливается скопированный обратный вызов для входа в систему."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "保持 Windows 游戏打开，同时恢复其复制的登录回调。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "保持 Windows 遊戲打開，同時恢復其複製的登入回呼。"
          }
        }
      }
    },
