    "Containers and portable manifests stay in this user-selected folder. Runtime caches and logs remain in their documented user-local locations.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Container und tragbare Manifeste bleiben in diesem vom Benutzer ausgewählten Ordner. Laufzeit-Caches und Protokolle bleiben an ihren dokumentierten lokalen Speicherorten des Benutzers."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los contenedores y manifiestos portátiles permanecen en esta carpeta seleccionada por el usuario. Los registros y cachés en tiempo de ejecución permanecen en sus ubicaciones locales de usuario documentadas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les conteneurs et les manifestes portables restent dans ce dossier sélectionné par l'utilisateur. Les caches et les journaux d'exécution restent dans leurs emplacements utilisateur locaux documentés."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "コンテナーとポータブル マニフェストは、ユーザーが選択したこのフォルダーに残ります。実行時のキャッシュとログは、文書化されたユーザーのローカルの場所に残ります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "컨테이너와 이동식 매니페스트는 사용자가 선택한 폴더에 저장합니다. 런타임 캐시와 로그는 문서에 안내된 사용자 전용 위치에 둡니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Os contêineres e manifestos portáteis ficam nesta pasta. Os caches do runtime e os registros permanecem nos locais do usuário indicados na documentação."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Контейнеры и переносимые манифесты остаются в этой папке, выбранной пользователем. Кэши и журналы среды выполнения остаются в своих задокументированных локальных расположениях у пользователя."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "容器和便携式清单保留在这个用户选择的文件夹中。运行时缓存和日志保留在其记录的用户本地位置。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "容器和便攜式清單保留在這個使用者選擇的資料夾中。運行時快取和日誌保留在其記錄的使用者本地位置。"
          }
        }
      }
    },
