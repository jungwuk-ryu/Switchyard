    "Refusing to move %@ to Trash because its path is outside Switchyard storage or has no Switchyard manifest.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das Verschieben von %1$@ in den Papierkorb wird abgelehnt, da der Pfad außerhalb des Switchyard-Speichers liegt oder kein Switchyard-Manifest vorhanden ist."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Negarse a mover %1$@ a la Papelera porque su ruta está fuera del almacenamiento Switchyard o no tiene ningún manifiesto Switchyard."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Refus de déplacer %1$@ vers la corbeille car son chemin se trouve en dehors du stockage Switchyard ou n'a pas de manifeste Switchyard."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "パスがSwitchyardの保存領域外にあるか、Switchyardマニフェストがないため、%1$@をゴミ箱に入れられません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@의 경로가 Switchyard 저장소 밖에 있거나 매니페스트가 없어 휴지통으로 옮기지 않았습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ não será movido para o Lixo porque o caminho está fora do armazenamento do Switchyard ou não contém um manifesto do Switchyard."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отказ в перемещении %1$@ в корзину, поскольку его путь находится за пределами хранилища Switchyard или не имеет манифеста Switchyard."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "拒绝将 %1$@ 移至垃圾箱，因为其路径位于 Switchyard 存储之外或没有 Switchyard 清单。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "拒絕將 %1$@ 移至垃圾箱，因為其路徑位於 Switchyard 儲存之外或沒有 Switchyard 清單。"
