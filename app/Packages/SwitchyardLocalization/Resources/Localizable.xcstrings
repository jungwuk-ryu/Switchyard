          "stringUnit": {
            "state": "translated",
            "value": "3. 返回這裡 — Switchyard 會自動找到它"
          }
        }
      }
    },
    "A Wine release does not include its runtime manifest.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Wine 릴리스에 런타임 매니페스트가 없습니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Wine 版本不包含运行时清单。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Wine 版本未包含執行環境資訊清單。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Wine リリースにランタイムマニフェストが含まれていません。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "В выпуске Wine отсутствует манифест среды выполнения."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Eine Wine-Version enthält kein Laufzeitmanifest."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Une version de Wine ne contient pas son manifeste d’environnement d’exécution."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Una versión de Wine no incluye su manifiesto del entorno de ejecución."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Uma versão do Wine não contém o manifesto do runtime."
          }
        }
      }
    },
    "A Wine release points to an untrusted runtime manifest.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Wine 릴리스가 신뢰할 수 없는 런타임 매니페스트를 가리킵니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Wine 版本指向了不受信任的运行时清单。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Wine 版本指向不受信任的執行環境資訊清單。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Wine リリースが信頼できないランタイムマニフェストを参照しています。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выпуск Wine ссылается на недоверенный манифест среды выполнения."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Eine Wine-Version verweist auf ein nicht vertrauenswürdiges Laufzeitmanifest."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Une version de Wine pointe vers un manifeste d’environnement d’exécution non fiable."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Una versión de Wine apunta a un manifiesto del entorno de ejecución que no es de confianza."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Uma versão do Wine aponta para um manifesto de runtime não confiável."
          }
        }
      }
    },
    "A Wine runtime manifest could not be verified: %@": {
